# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# Optional: send admin notifications to a dedicated Telegram group/channel chat.
# Recommended: use a private group and put its chat id here (usually starts with -100)
ADMIN_TELEGRAM_CHAT_ID=

# Legacy fallback. Kept for compatibility only.
# Private user IDs are ignored by default to avoid mixing admin logs into the bot DM.
ADMIN_TELEGRAM_ID=

# ─── Database (NeonDB PostgreSQL) ────────────────────────────────────────────
# Paste your Neon/PostgreSQL connection string here
DATABASE_URL=

# ─── Telegram MTProto API (User Bot) ─────────────────────────────────────────
# Get these from https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=26595605
TELEGRAM_API_HASH=c3cd2ad59f144c3a8dda160b65f7228f

# Optional: pre-authorized GramJS session string.
# If you set this, end-users do not need to run /login in chat.
TELEGRAM_SESSION_STRING=

# Optional GramJS log level: none | error | warn | info | debug
TELEGRAM_LOG_LEVEL=warn

# Path where the MTProto session string is persisted (relative to project root)
SESSION_FILE=session.txt

# ─── Telegram Bot API (Bot Token) ────────────────────────────────────────────
# Create a bot via @BotFather → /newbot → copy the token here
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLMnopQRSTuvwxyz
